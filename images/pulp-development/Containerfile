ARG VERSION=3.105
FROM quay.io/pulp/pulp:${VERSION}

# Re-declare ARG to make it available after FROM
ARG VERSION=3.105
ARG PULPCORE_VERSION=3.105.1
ARG PULP_ANSIBLE_VERSION=0.29.6
ARG PULP_CONTAINER_VERSION=2.27.3
ARG PULP_RPM_VERSION=3.35.2
ARG PULP_OSTREE_VERSION=2.6.0
ARG PULP_PYTHON_VERSION=3.27.0
ARG PULP_DEB_VERSION=3.8.1

# Install git and build dependencies
#USER root

ENV PULP_GUNICORN_TIMEOUT=${PULP_GUNICORN_TIMEOUT:-90}
ENV PULP_API_WORKERS=${PULP_API_WORKERS:-2}
ENV PULP_API_WORKERS_MAX_REQUESTS=${PULP_API_WORKERS_MAX_REQUESTS:-800}
ENV PULP_API_WORKERS_MAX_REQUESTS_JITTER=${PULP_API_WORKERS_MAX_REQUESTS_JITTER:-100}
ENV PULP_CONTENT_WORKERS=${PULP_CONTENT_WORKERS:-2}

RUN dnf install -y git gcc python3-devel sed unzip zip && dnf clean all

